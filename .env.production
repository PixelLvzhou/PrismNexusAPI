# ============================================
# Prism Nexus 后端生产环境配置
# ============================================

# QQ邮箱SMTP配置（用于发送验证码）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=你的QQ邮箱@qq.com
SMTP_PASS=你的SMTP授权码

# Redis配置（可选，如不需要可删除或注释）
# REDIS_HOST=localhost
# REDIS_PORT=6379

# 服务端口
PORT=3000

# JWT配置（建议修改为更复杂的密钥）
JWT_SECRET=你的JWT密钥（建议使用随机字符串，至少32位）
JWT_EXPIRES_IN=24h
